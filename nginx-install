#!/bin/bash

# update apt, upgrade system and install nginx, nodejs and npm
echo -e "\e[34mUpdating apt & system and installing nginx\e[0m"
sudo apt update && sudo apt upgrade -y
sudo apt install nginx nodejs npm -y
echo -e "✅ \e[32mSuccessfully installed Nginx, NodeJS and npm\e[0m"
nginx -v

# configure firewall
echo -e "\n\e[34mConfiguring firewall ...\e[0m"
echo "Checking firewall status ..."
sudo ufw status
echo "Enabling ssh (22), http (80) and https (443) ports ..."
sudo ufw allow ssh
sudo ufw allow http
sudo ufw allow https
sudo ufw --force enable
echo -e "✅ \e[32mSuccessfully activated the firewall and allowed ssh, http and https ports\e[0m"
sudo ufw status
echo -e "Visit your website (served by nginx) by typing your server ip in your browser, like so: \e[34mhttp://your_server_ip\e[0m"

# setup nginx-facts-website + sites available and enabled
echo -e "\n\e[34mSetting up the website and nginx configs ...\e[0m"
sudo mkdir -p /var/www/nginx-facts-website/html
sudo cp -r demo-website/frontend/build/* /var/www/nginx-facts-website/html/
sudo echo '
server {
    server_name ubuntuserver.lab;
    root /var/www/nginx-facts-website/html;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location /api/facts {
        proxy_pass http://127.0.0.1:5000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }
}
' > /etc/nginx/sites-available/nginx-facts
sudo ln -s /etc/nginx/sites-available/nginx-facts /etc/nginx/sites-enabled/
sudo nginx -t
sudo systemctl reload nginx
echo -e "\n✅ \e[32mNginx configs for the website successfully setup\e[0m"

# setup separate folder user's home to store and run the expressjs api
echo -e "\n\e[34mSetting up the api and pm2 ...\e[0m"
mkdir -p "$HOME/apis/nginx-facts"
sudo cp -r demo-website/backend/* "$HOME/apis/nginx-facts"
cd "$HOME/apis/nginx-facts"
npm i

# installing pm2 for a persistent running server across reboots
sudo npm install -g pm2
pm2 start server.js --name "nginx-facts-api"
# eval $(pm2 startup | tail -n 1)
pm2startup_setup=$(pm2 startup | grep "sudo " | tail -n 1)
if [ -n "$pm2startup_setup" ]; then
    eval "$pm2startup_setup"
    pm2 save
    echo -e "\n✅ \e[32mAPI and pm2 successfully configured\e[0m"
else
    echo "Could not find the startup command. Maybe it's already configured?"
fi
pm2 status